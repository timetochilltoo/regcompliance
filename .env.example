# Copy this file to .env and fill in the API key for whichever providers you use.
# Only the keys for providers you've selected need to be filled in.

# ============================================================================
# LLM PROVIDER (for answer generation)
# ============================================================================
# Pick one of: openai | deepseek | anthropic | minimax
LLM_PROVIDER=minimax

# --- MiniMax (default; HK-accessible, no VPN) ---
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-M3
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
# NOTE: minimaxi.com (not minimax.com). The chat endpoint is OpenAI-compatible.

# --- OpenAI (needs VPN in HK) ---
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# --- DeepSeek (OpenAI-compatible) ---
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat
# (Set LLM_PROVIDER=openai and OPENAI_BASE_URL=https://api.deepseek.com)

# --- Anthropic (needs VPN in HK) ---
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-haiku-latest


# ============================================================================
# EMBEDDING PROVIDER (for vector search — runs once per ingest)
# ============================================================================
# Pick one of: openai | minimax | jina
# Default is openai (industry standard). To switch, change EMBEDDING_PROVIDER
# and re-run: python -m src.crawl --reembed-only
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# --- OpenAI (default; needs VPN in HK; ~$0.07 one-time for 62 PDFs) ---
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small   # or text-embedding-3-large (3072-dim)
OPENAI_EMBEDDING_DIM=1536

# --- MiniMax (HK-accessible, no VPN) ---
# EMBEDDING_PROVIDER=minimax
# MINIMAX_API_KEY=                 # same key as the LLM
# MINIMAX_EMBEDDING_MODEL=embo-01
# MINIMAX_EMBEDDING_DIM=1536
# Note: MiniMax embeddings endpoint is NOT OpenAI-compatible. Uses
# payloads like {texts: [...], type: "db"|"query"}. The code handles this.

# --- Jina AI (free tier: 1M tokens/month; multilingual) ---
# EMBEDDING_PROVIDER=jina
# JINA_API_KEY=
# JINA_EMBEDDING_MODEL=jina-embeddings-v3
# JINA_EMBEDDING_DIM=1024
# JINA_BASE_URL=https://api.jina.ai/v1


# ============================================================================
# USAGE
# ============================================================================
#   python -m src.crawl                  # full crawl (download + chunk + embed)
#   python -m src.crawl --reembed-only   # re-embed existing chunks with current provider
#   python -m src.crawl --reingest       # wipe everything and start fresh
#
# Workflow tip: embeddings are a one-time cost. Pick a provider, run ingest
# once, then use the system. Re-run only when IA HK publishes new guidelines.
