# Copy this file to .env and fill in your API key(s).
# You only need to set the key for the provider you've selected in LLM_PROVIDER.

# --- LLM provider selection ---
# Pick one of: openai | deepseek | anthropic | minimax
LLM_PROVIDER=openai

# --- OpenAI (default provider) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
# Optional: point to a different OpenAI-compatible endpoint
# OPENAI_BASE_URL=https://api.deepseek.com

# --- DeepSeek (uncomment if using) ---
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_MODEL=deepseek-chat
# (set LLM_PROVIDER=openai and OPENAI_BASE_URL=https://api.deepseek.com to use it)

# --- Anthropic (uncomment if using) ---
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-haiku-latest

# --- MiniMax (uncomment if using) ---
# MINIMAX_API_KEY=...
# MINIMAX_MODEL=MiniMax-M2.7
# MINIMAX_BASE_URL=https://api.minimax.chat/v1

# --- Embedding model ---
# text-embedding-3-small is the cheapest good option from OpenAI
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
