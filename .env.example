# Copy this file to .env and fill in your API key(s).

# --- LLM provider selection ---
# Pick one of: openai | deepseek | anthropic | minimax
LLM_PROVIDER=minimax

# --- MiniMax (default provider) ---
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-M3
MINIMAX_BASE_URL=https://api.minimax.com/v1

# --- OpenAI (used for embeddings; MiniMax also has its own embedding model) ---
# Leave OPENAI_API_KEY blank if you set EMBEDDING_PROVIDER=minimax below.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.deepseek.com   # optional: point to a different OpenAI-compatible endpoint

# --- DeepSeek (OpenAI-compatible) ---
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat

# --- Anthropic ---
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-haiku-latest

# --- Embedding provider ---
# Set to "minimax" to use MiniMax's embo-01 (free with your MiniMax key).
# Set to "openai" to use OpenAI's text-embedding-3-small (~$0.10 one-time).
EMBEDDING_PROVIDER=minimax
EMBEDDING_MODEL=embo-01
EMBEDDING_DIM=1536
